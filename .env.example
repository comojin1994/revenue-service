# Supabase project URL (https://<project-ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url

# Supabase anon/public key (safe for browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service-role key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Private storage bucket name used for downloaded videos.
SUPABASE_STORAGE_BUCKET=videos

# OpenAI API key for Whisper transcription — SERVER ONLY. Never expose to the browser.
OPENAI_API_KEY=your-openai-api-key

# Private storage bucket for generated SRT transcripts.
SUPABASE_TRANSCRIPTS_BUCKET=transcripts
